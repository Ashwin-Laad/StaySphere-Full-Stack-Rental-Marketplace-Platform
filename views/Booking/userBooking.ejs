<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
 <link rel="stylesheet" href="/output.css">
</head>
<body class="bg-gray-50 font-sans">

  <div class="min-h-screen py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-5xl mx-auto">

      <!-- Page Header -->
      <h1 class="text-3xl font-bold text-gray-800 mb-8">My Bookings</h1>

      <% if(booking.length === 0) { %>
        <p class="text-gray-600 text-center mt-8">You have no bookings yet. <a href="/home-list" class="text-blue-600 underline">Browse homes</a> to make a booking.</p>
      <% } else { %>

        <!-- Booking List -->
        <div class="grid gap-6">
         
            <div class="bg-white rounded-2xl shadow-md p-6 flex flex-col md:flex-row items-start md:items-center justify-between">

              <!-- Booking Info -->
              <div class="mb-4 md:mb-0">
                <h2 class="text-xl font-semibold text-gray-800 mb-1"><%= booking.home.houseName %></h2>
                <p class="text-gray-600 mb-1">Location: <%= booking.home.location %></p>
                <p class="text-gray-600 mb-1">Check-in: <%= new Date(booking.checkIn).toDateString() %></p>
                <p class="text-gray-600 mb-1">Check-out: <%= new Date(booking.checkOut).toDateString() %></p>
                <p class="text-gray-700 font-semibold">Total Price: ₹<%= booking.totalPrice %></p>
                <p class="text-sm font-medium mt-2">
                  Status: 
                  <% if(new Date(booking.checkOut) < new Date()){ %>
                    <span class="text-gray-500">Completed</span>
                  <% } else { %>
                    <span class="text-green-600">Upcoming</span>
                  <% } %>
                </p>
              </div>

              <!-- Action Buttons -->
              <div class="flex flex-col md:flex-row gap-2 md:gap-3">
                <a href="/home-detail/<%= booking.home._id %>" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition duration-200 text-center">View Details</a>
                <% if(new Date(booking.checkIn) > new Date()) { %>
                  <form action="/booking/cancel/<%= booking._id %>" method="POST">
                    <button type="submit" class="px-4 py-2 bg-red-500 text-white rounded-lg hover:bg-red-600 transition duration-200">Cancel</button>
                  </form>
                <% } %>
              </div>

            </div>
     
        </div>

      <% } %>

    </div>
  </div>

</body>
</html>