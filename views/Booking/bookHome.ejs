<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/output.css">
</head>
<body class="bg-gray-50 font-sans">

  <!-- Container -->
  <div class="min-h-screen flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full bg-white shadow-lg rounded-xl p-8">

      <!-- Header -->
      <h1 class="text-3xl font-bold text-gray-800 mb-6">Book This Home</h1>

      <!-- Home Info -->
      <div class="mb-6">
        <p class="text-gray-700 font-semibold mb-2">Home: <%= home.houseName %></p>
        <p class="text-gray-600 mb-1">Price per night: ₹<%= home.pricePerNight %></p>
        <p class="text-gray-600">Location: <%= home.location %></p>
      </div>

      <!-- Booking Form -->
      <form action="/BookHome" method="POST" class="space-y-4">
        <!-- Hidden input to send home ID -->
        <input type="hidden" name="homeId" value="<%= home._id %>">
         <input type="hidden" name="price" value="<%= home.pricePerNight %>">
        <!-- Check-in -->
        <div>
          <label for="checkIn" class="block text-gray-700 mb-1 font-medium">Check-in Date</label>
          <input type="date" id="checkIn" name="checkIn" required 
                 class="w-full border-gray-300 rounded-lg p-2 focus:ring-blue-500 focus:border-blue-500" 
                 >
        </div>

        <!-- Check-out -->
        <div>
          <label for="checkOut" class="block text-gray-700 mb-1 font-medium">Check-out Date</label>
          <input type="date" id="checkOut" name="checkOut" required
                 class="w-full border-gray-300 rounded-lg p-2 focus:ring-blue-500 focus:border-blue-500"
                >
        </div>

      

        <!-- Submit Button -->
        <button type="submit" 
          class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 rounded-lg transition duration-200">
          Confirm Booking
        </button>
      </form>

    </div>
  </div>