<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Booking Status</title>
  <link rel="stylesheet" href="/output.css">

</head>
<body class="bg-gray-50 font-sans">

  <div class="min-h-screen flex items-center justify-center">
    <div class="bg-white shadow-lg rounded-xl p-8 max-w-md w-full text-center">
      <!-- Header -->
      <h1 class="text-3xl font-bold text-red-600 mb-4">House Already Booked</h1>
      
      <!-- Message -->
      <p class="text-gray-700 text-lg mb-6">
        <%= message %>
      </p>

      <!-- Next available date -->
      <div class="bg-gray-100 rounded-lg p-4 mb-6">
        <h2 class="text-gray-800 font-semibold mb-2">Next Available Date:</h2>
        <p class="text-gray-900 text-xl font-bold">
          <%= new Date(nextAvailableDate).toLocaleDateString('en-IN', { weekday: 'long', year: 'numeric', month: 'short', day: 'numeric' }) %>
        </p>
      </div>

      <!-- Action button -->
      <a href="/" class="inline-block bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-6 rounded-lg transition-all duration-200">
        View Other Homes
      </a>
    </div>
  </div>

</body>
</html>