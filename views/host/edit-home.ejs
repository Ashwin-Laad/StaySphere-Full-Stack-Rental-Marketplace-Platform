<%- include("../partials/header") %>

<div class="flex justify-center items-center min-h-screen px-4 bg-gray-100 mt-20">
  <div class="w-full max-w-lg bg-white rounded-2xl shadow-sm p-8 border border-gray-200">

    <h1 class="text-2xl font-semibold text-gray-900 text-center mb-6">
      Edit your Home 🏡
    </h1>

    <form action="/edit-home" method="POST" class="space-y-5" enctype="multipart/form-data">

      <!-- Host Name -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Host Name</label>
        <input type="text" name="host" value="<%= home.host %>" required
          class="w-full px-4 py-2 rounded-lg border border-gray-300 bg-white text-gray-900 text-sm
          focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition">
      </div>

      <!-- Hidden ID -->
      <input type="hidden" name="id" value="<%= home._id %>">

      <!-- House Name -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">House Name</label>
        <input type="text" name="houseName" value="<%= home.houseName %>" required
          class="w-full px-4 py-2 rounded-lg border border-gray-300 bg-white text-gray-900 text-sm
          focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition">
      </div>

      <!-- Price -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Price per Night (₹)</label>
        <input type="number" name="pricePerNight" value="<%= home.pricePerNight %>" required
          class="w-full px-4 py-2 rounded-lg border border-gray-300 bg-white text-gray-900 text-sm
          focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition">
      </div>

      <!-- Location -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Location</label>
        <input type="text" name="location" value="<%= home.location %>" required
          class="w-full px-4 py-2 rounded-lg border border-gray-300 bg-white text-gray-900 text-sm
          focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition">
      </div>

      <!-- Rating -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Rating (1 to 5)</label>
        <input type="number" name="rating" min="1" max="5" step="0.1" value="<%= home.rating %>"
          class="w-full px-4 py-2 rounded-lg border border-gray-300 bg-white text-gray-900 text-sm
          focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition">
      </div>

      <!-- Photo -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Photo</label>
        <input type="file" name="photo"
          class="w-full px-4 py-2 rounded-lg border border-gray-300 bg-white text-gray-900 text-sm
          focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition">
      </div>

      <!-- Description -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
        <textarea name="description" rows="4"
          class="w-full px-4 py-2 rounded-lg border border-gray-300 bg-white text-gray-900 text-sm
          focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition"><%= home.description %></textarea>
      </div>

      <!-- Submit Button -->
      <button type="submit"
        class="w-full py-2.5 rounded-lg bg-blue-600 hover:bg-blue-700 text-white font-medium text-sm shadow-sm transition">
        Update Details
      </button>

    </form>
  </div>
</div>