<%- include('../partials/header') %>
<main class="max-w-7xl mx-auto px-6 py-10 bg-gray-100 pt-28">

  <h1 class="text-3xl font-bold text-center text-blue-600 mb-10">
    Host, these are your homes 🏡
  </h1>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">

    <% RegisteredHouse.forEach((element) => { %>

      <div class="bg-white rounded-2xl shadow-sm overflow-hidden border border-gray-200 transition duration-300">

        <!-- Image -->
        <div class="h-48 w-full overflow-hidden">
          <img 
            src="<%= element.photo || 'https://images.unsplash.com/photo-1568605114967-8130f3a36994' %>" 
            alt="House Image"
            class="w-full h-full object-cover"
          >
        </div>

        <!-- Content -->
        <div class="p-5 space-y-2">

          <h2 class="text-xl font-bold text-gray-900">
            <%= element.houseName %>
          </h2>

          <p class="text-sm text-gray-600">
            📍 <%= element.location || 'Unknown location' %>
          </p>

          <p class="text-sm text-gray-600">
            👤 Host: <%= element.host%>
          </p>

          <div class="flex justify-between items-center mt-3">

            <span class="text-lg font-semibold text-blue-600">
              ₹<%= element.pricePerNight %> / night
            </span>

            <span class="text-sm bg-yellow-100 text-yellow-600 px-2 py-1 rounded-lg">
              ⭐ <%= element.rating || 'N/A' %>
            </span>

          </div>

        </div>

        <!-- Actions -->
        <div class="p-5 space-y-2">
          <a href="/host/edit-home/<%= element._id%>?edit=true"
             class="w-full block text-center bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 rounded-lg transition shadow-sm">
            Edit
          </a>

          <form method="post" action="/host/delete-home/<%= element._id %>">
            <button type="submit"
              class="w-full bg-red-500 hover:bg-red-600 text-white font-semibold py-2 rounded-lg transition shadow-sm">
              Delete
            </button>
          </form>
        </div>

      </div>

    <% }); %>

  </div>

</main>