<%- include("../partials/header") %>

<main class="flex justify-center items-center min-h-screen bg-gray-100 px-4">

  <div class="w-full max-w-md bg-white rounded-2xl shadow-sm p-8 mt-20">

    <!-- Form Title -->
    <h2 class="text-2xl font-semibold text-gray-900 text-center mb-6">Create Your Account</h2>
    <p class="text-sm text-gray-500 text-center mb-6">Sign up to get started</p>

    <!-- Global Errors -->
    <% if (errors.length > 0) { %>
      <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-lg mb-5">
        <strong class="font-medium">Oops!</strong>
        <ul class="mt-1 list-disc list-inside space-y-1">
          <% errors.forEach(error => { %>
            <li><%= error %></li>
          <% }) %>
        </ul>
      </div>
    <% } %>

    <form action="/signup" method="POST" class="space-y-5">

      <!-- Name Fields -->
      <div class="flex flex-col sm:flex-row gap-4">
        <div class="flex-1">
          <label class="block text-sm font-medium text-gray-700 mb-1">First Name</label>
          <input type="text" name="firstName" value="<%= oldInput.firstName || '' %>"
            class="w-full px-4 py-2 rounded-lg border <%= errors?.find(e => e.includes('First Name')) ? 'border-red-500' : 'border-gray-300' %> 
            bg-white text-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition shadow-sm">
        </div>
        <div class="flex-1">
          <label class="block text-sm font-medium text-gray-700 mb-1">Last Name</label>
          <input type="text" name="lastName" value="<%= oldInput.lastName || '' %>"
            class="w-full px-4 py-2 rounded-lg border border-gray-300 bg-white text-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition shadow-sm">
        </div>
      </div>

      <!-- Email -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
        <input type="email" name="email" value="<%= oldInput.email || '' %>"
          class="w-full px-4 py-2 rounded-lg border border-gray-300 bg-white text-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition shadow-sm">
      </div>

      <!-- Password -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Password</label>
        <input type="password" name="password"
          class="w-full px-4 py-2 rounded-lg border border-gray-300 bg-white text-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition shadow-sm">
      </div>

      <!-- Confirm Password -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Confirm Password</label>
        <input type="password" name="confirmPassword"
          class="w-full px-4 py-2 rounded-lg border border-gray-300 bg-white text-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition shadow-sm">
      </div>

      <!-- Role Selection -->
      <div>
        <label class="block text-sm font-medium mb-2 text-gray-700">Account Type</label>
        <div class="flex gap-6">
          <label class="flex items-center gap-2 text-gray-700">
            <input type="radio" name="role" value="guest" <%= oldInput.role === "guest" ? "checked" : "" %>
              class="accent-blue-500 w-5 h-5">
            Guest
          </label>
          <label class="flex items-center gap-2 text-gray-700">
            <input type="radio" name="role" value="host" <%= oldInput.role === "host" ? "checked" : "" %>
              class="accent-blue-500 w-5 h-5">
            Host
          </label>
        </div>
      </div>

      <!-- Terms -->
      <div class="flex items-center gap-2 text-gray-600 text-sm">
        <input type="checkbox" name="terms" <%= oldInput.terms ? "checked" : "" %> class="accent-blue-500 w-4 h-4">
        <span>I agree to <a href="#" class="text-blue-600 underline">Terms & Conditions</a></span>
      </div>

      <!-- Submit Button -->
      <button type="submit"
        class="w-full py-2.5 rounded-lg bg-blue-600 hover:bg-blue-700 transition-colors font-semibold text-white shadow-sm">
        Sign Up
      </button>

      <!-- Login Link -->
      <p class="text-center text-sm text-gray-600 mt-3">
        Already have an account?
        <a href="/login" class="text-blue-600 hover:underline">Login</a>
      </p>

    </form>
  </div>

</main>