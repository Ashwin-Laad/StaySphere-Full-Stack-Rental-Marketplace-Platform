<%/*To display all available homes to the user getting via model from array and showing it*/%>

<%- include('../partials/header') %>

<main class="max-w-7xl mx-auto px-6 py-10 pt-28 bg-gray-100">

  <h1 class="text-3xl font-bold text-center text-blue-600 mb-10">
    Available Homes 🏡
  </h1>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">

    <% RegisteredHouse.forEach((element) => { %>

      <div class="bg-white rounded-2xl shadow-sm overflow-hidden transition hover:shadow-lg border border-gray-200">

        <!-- Image -->
        <div class="h-48 w-full overflow-hidden">
          <img 
            src="<%= element.photo || 'https://images.unsplash.com/photo-1568605114967-8130f3a36994' %>" 
            alt="House Image"
            class="w-full h-full object-cover transition-transform duration-300 hover:scale-105"
          >
        </div>

        <!-- Content -->
        <div class="p-5 space-y-3">

          <h2 class="text-xl font-bold text-gray-900">
            <%= element.houseName %>
          </h2>

          <p class="text-sm text-gray-600">
            📍 <%= element.location || 'Unknown location' %>
          </p>

          <p class="text-sm text-gray-600">
            👤 Host: <%= element.host %>
          </p>

          <div class="flex justify-between items-center mt-4">
            <span class="text-lg font-semibold text-blue-600">
              ₹<%= element.pricePerNight %> / night
            </span>

            <span class="text-sm bg-yellow-100 text-yellow-600 px-2 py-1 rounded-lg">
              ⭐ <%= element.rating || 'N/A' %>
            </span>
          </div>

          <!-- Buttons -->
          <div class="flex flex-col gap-3 mt-5">

            <a 
              href="/home-detail/<%= element._id %>"
              class="block w-full text-center py-3 rounded-lg border border-blue-500 text-blue-600 font-medium hover:bg-blue-500 hover:text-white shadow-sm transition"
            >
              View Details
            </a>

            <a 
              href="/booking/<%= element._id %>"
              class="block w-full text-center py-3 rounded-lg bg-blue-600 text-white font-semibold hover:bg-blue-700 shadow-sm transition"
            >
              Book
            </a>

            <%- include("../partials/favorite",{element:element}) %>

          </div>

        </div>

      </div>

    <% }); %>

  </div>

</main>