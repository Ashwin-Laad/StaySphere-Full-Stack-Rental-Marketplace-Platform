<%/* To display all available homes on the front page */%>

<%- include('../partials/header') %>
<main class="max-w-7xl mx-auto px-6 py-10 pt-24">

  <h1 class="text-3xl font-bold text-center text-blue-400 mb-10">
   Welcome to the Air-BnB Front Page 🏡
  </h1>

 <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">

  <% RegisteredHouse.forEach((element) => { %>
    <div class="bg-white rounded-2xl shadow-md overflow-hidden border border-gray-200 hover:shadow-lg transition duration-300">
      
      <!-- Image -->
      <div class="h-40 w-full overflow-hidden">
        <img 
          src="<%= element.photo || 'https://images.unsplash.com/photo-1568605114967-8130f3a36994' %>" 
          alt="House Image"
          class="w-full h-full object-cover hover:scale-105 transition duration-300"
        >
      </div>

      <!-- Content -->
      <div class="p-4 space-y-2">
        <h2 class="text-lg font-bold text-gray-900">
          <%= element.houseName %>
        </h2>

        <p class="text-sm text-gray-500">📍 <%= element.location || 'Unknown location' %></p>
        <p class="text-sm text-gray-500">👤 Host: <%=element.host%></p>

        <div class="flex justify-between items-center mt-2">
          <span class="text-sm font-semibold text-gray-800">₹<%= element.pricePerNight %> / night</span>
          <span class="text-xs bg-yellow-100 text-yellow-600 px-2 py-0.5 rounded-md">⭐ <%= element.rating || 'N/A' %></span>
        </div>

        <a href="/booking/<%=element._id %>" 
           class="mt-2 w-full text-center block bg-blue-500 hover:bg-blue-600 text-white font-medium py-1.5 rounded-md text-sm transition shadow-sm">
          Book
        </a>

        <form action="/favorite" method="post" class="mt-1">
          <input type="hidden" name="id" value="<%= element._id %>">
 
        </form>

      </div>
    </div>
  <% }); %>

</div>

</main>
</body>
</html>