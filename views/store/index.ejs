<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>StaySphere</title>
  <link rel="stylesheet" href="/output.css">
</head>

<body class="bg-gray-50 text-gray-900">

<main>

  <!-- 🔥 HERO WITH IMAGE -->
  <section class="relative h-[90vh] flex items-center justify-center text-center">

    <!-- Background Image -->
    <div class="absolute inset-0">
      <img 
        src="https://images.unsplash.com/photo-1505693416388-ac5ce068fe85"
        class="w-full h-full object-cover"
      >
      <div class="absolute inset-0 bg-black/50"></div>
    </div>

    <!-- Content -->
    <div class="relative z-10 text-white px-6">
      <h1 class="text-5xl md:text-6xl font-extrabold leading-tight">
        Discover Your Perfect Stay
      </h1>

      <p class="mt-6 text-lg max-w-2xl mx-auto text-gray-200">
        StaySphere lets you explore, book, and host unique homes effortlessly.
      </p>

      <div class="mt-8 flex justify-center gap-4">
        <a href="/login"
           class="px-8 py-3 bg-blue-600 text-white font-semibold rounded-lg shadow hover:bg-blue-700 transition">
          Explore Homes
        </a>

        <a href="/host/add-home"
           class="px-8 py-3 bg-white text-gray-900 font-semibold rounded-lg hover:bg-gray-200 transition">
          Become a Host
        </a>
      </div>
    </div>

  </section>

  <!-- 🔥 FEATURES WITH IMAGES -->
  <section class="max-w-7xl mx-auto px-6 py-16 grid grid-cols-1 md:grid-cols-3 gap-6">

    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
      <img src="https://images.unsplash.com/photo-1560448204-e02f11c3d0e2" class="h-40 w-full object-cover">
      <div class="p-5 text-center">
        <h3 class="text-lg font-semibold">Seamless Booking</h3>
        <p class="mt-2 text-gray-600 text-sm">
          Browse homes and book instantly with a smooth experience.
        </p>
      </div>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
      <img src="https://images.unsplash.com/photo-1522708323590-d24dbb6b0267" class="h-40 w-full object-cover">
      <div class="p-5 text-center">
        <h3 class="text-lg font-semibold">Host with Ease</h3>
        <p class="mt-2 text-gray-600 text-sm">
          List your property and manage everything effortlessly.
        </p>
      </div>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
      <img src="https://images.unsplash.com/photo-1507089947368-19c1da9775ae" class="h-40 w-full object-cover">
      <div class="p-5 text-center">
        <h3 class="text-lg font-semibold">Smart Experience</h3>
        <p class="mt-2 text-gray-600 text-sm">
          Built with a fast, responsive, and modern interface.
        </p>
      </div>
    </div>

  </section>

  <!-- 🔥 CTA -->
  <section class="bg-blue-600 py-16 text-center text-white">
    <h2 class="text-3xl font-bold">
      Ready to find your next stay?
    </h2>

    <p class="mt-3 text-blue-100">
      Join StaySphere and explore homes across the platform.
    </p>

    <a href="/login"
       class="inline-block mt-6 px-8 py-3 bg-white text-blue-600 font-semibold rounded-lg hover:bg-gray-100 transition">
      Get Started
    </a>
  </section>

</main>

</body>
</html>