<%- include('../partials/header') %>

<main class="max-w-7xl mx-auto px-6 py-10 bg-gray-100 pt-28">

  <h1 class="text-3xl font-bold text-center text-blue-600 mb-10">
    Home Detail Page 🏡
  </h1>

  <div class="max-w-4xl mx-auto bg-white rounded-2xl shadow-sm overflow-hidden border border-gray-200">

    <!-- Image -->
    <div class="h-64 w-full overflow-hidden">
      <img 
        src="/uploads/<%= element.photo %>"
        alt="House Image"
        class="w-full h-full object-cover"
      >
    </div>

    <!-- Content -->
    <div class="p-6 space-y-3">

      <h2 class="text-2xl font-bold text-gray-900">
        <%= element.houseName %>
      </h2>

      <p class="text-gray-600">
        📍 <%= element.location || 'Unknown location' %>
      </p>

      <p class="text-gray-600">
        👤 Host: <%= element.host %>
      </p>

      <div class="flex justify-between items-center mt-4">

        <span class="text-lg font-semibold text-blue-600">
          ₹<%= element.pricePerNight %> / night
        </span>

        <span class="text-sm bg-yellow-100 text-yellow-600 px-2 py-1 rounded-lg">
          ⭐ <%= element.rating || 'N/A' %>
        </span>

      </div>

      <div class="flex flex-col sm:flex-row gap-4 mt-6">

        <a href="/booking/<%= element._id %>"
           class="flex-1 text-center bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 rounded-lg shadow-sm transition">
          Book
        </a>

        <a href="/store/rule/<%= element._id %>"
           class="flex-1 text-center bg-transparent border border-blue-500 text-blue-600 font-medium py-3 rounded-lg hover:bg-blue-500 hover:text-white transition shadow-sm">
          Download Rules
        </a>

      </div>

    </div>

  </div>

</main>