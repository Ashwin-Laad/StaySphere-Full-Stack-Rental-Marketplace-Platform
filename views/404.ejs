<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>404 | Page Not Found</title>
  <link rel="stylesheet" href="/output.css">
</head>
<body class="bg-gradient-to-b from-gray-900 via-gray-800 to-black text-gray-100 flex items-center justify-center min-h-screen px-4">

  <main class="text-center space-y-8">
    <!-- Big 404 -->
    <h1 class="text-9xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-blue-400 via-indigo-500 to-purple-600 animate-pulse">
      404
    </h1>

    <!-- Message -->
    <p class="text-xl md:text-2xl font-semibold text-gray-300">
      Oops! The page you're looking for isn't here.
    </p>
    <p class="text-gray-400 max-w-md mx-auto">
      It might have been removed, renamed, or is temporarily unavailable.
    </p>

    <!-- Button -->
    <a href="/" class="inline-block mt-6 px-8 py-3 bg-blue-500 hover:bg-blue-600 text-white font-semibold rounded-lg shadow-lg transition duration-300 hover:shadow-xl">
      Go Home
    </a>

   
  </main>

</body>
</html>